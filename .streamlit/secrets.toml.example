# secrets.toml.example — Template untuk setup secrets Gemini API
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUKSI:
#   1. Salin file ini: cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   2. Isi api_keys dengan API key Gemini dari masing-masing akun Google anggota tim
#   3. JANGAN commit secrets.toml ke repo (sudah di-gitignore)
#
# PENTING — Cara kerja quota (per Jun 2026):
#   Rate limit Gemini API di-enforce PER GOOGLE CLOUD PROJECT, bukan per key.
#   Strategi multi-key HANYA efektif jika tiap key berasal dari akun Google
#   yang BENAR-BENAR BERBEDA (1 project = 1 akun = 1 pool quota).
# ─────────────────────────────────────────────────────────────────────────────

[gemini]
api_keys = [
  "YOUR_KEY_1_FROM_ACCOUNT_A",   # key milik kamu (akun Google kamu sendiri)
  "YOUR_KEY_2_FROM_ACCOUNT_B",   # key rekan 1 — WAJIB dari Google account berbeda
  "YOUR_KEY_3_FROM_ACCOUNT_C",   # key rekan 2 — WAJIB dari Google account berbeda
]
